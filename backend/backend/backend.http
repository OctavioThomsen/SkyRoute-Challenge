@backend_HostAddress = http://localhost:5000
@api_base = {{backend_HostAddress}}/api

### =====================================================================
###  FLIGHTS — POST /api/flights/search
###  Returns: { matches: SearchResponse[], suggestions: SearchResponse[] }
###  Exact match  → same origin + destination + date + cabin
###  Suggestions  → same route + cabin, different date
### =====================================================================

# Exact match: JFK → EZE, Economy (2026-06-11 — has flights)
POST {{api_base}}/flights/search
Content-Type: application/json

{
  "origin": "JFK",
  "destination": "EZE",
  "departureDate": "2026-06-11",
  "passengers": 2,
  "cabinClass": "Economy"
}

###

# Exact match: JFK → LAX, Economy — domestic route (isInternational=false)
POST {{api_base}}/flights/search
Content-Type: application/json

{
  "origin": "JFK",
  "destination": "LAX",
  "departureDate": "2026-06-11",
  "passengers": 1,
  "cabinClass": "Economy"
}

###

# Exact match: ATL → AEP, Business
POST {{api_base}}/flights/search
Content-Type: application/json

{
  "origin": "ATL",
  "destination": "AEP",
  "departureDate": "2026-06-14",
  "passengers": 1,
  "cabinClass": "Business"
}

###

# Exact match: MIA → EZE, FirstClass
POST {{api_base}}/flights/search
Content-Type: application/json

{
  "origin": "MIA",
  "destination": "EZE",
  "departureDate": "2026-06-12",
  "passengers": 1,
  "cabinClass": "FirstClass"
}

###

# No exact matches — date with no flights → suggestions only
POST {{api_base}}/flights/search
Content-Type: application/json

{
  "origin": "JFK",
  "destination": "EZE",
  "departureDate": "2026-06-13",
  "passengers": 1,
  "cabinClass": "Economy"
}

###

# Validation error: past date (400)
POST {{api_base}}/flights/search
Content-Type: application/json

{
  "origin": "JFK",
  "destination": "EZE",
  "departureDate": "2020-01-01",
  "passengers": 1,
  "cabinClass": "Economy"
}

###

# Validation error: origin == destination (400)
POST {{api_base}}/flights/search
Content-Type: application/json

{
  "origin": "JFK",
  "destination": "JFK",
  "departureDate": "2026-06-15",
  "passengers": 1,
  "cabinClass": "Economy"
}

###

# Validation error: invalid airport code (400)
POST {{api_base}}/flights/search
Content-Type: application/json

{
  "origin": "ZZZ",
  "destination": "EZE",
  "departureDate": "2026-06-15",
  "passengers": 1,
  "cabinClass": "Economy"
}

###

# Validation error: passengers out of range (400)
POST {{api_base}}/flights/search
Content-Type: application/json

{
  "origin": "JFK",
  "destination": "EZE",
  "departureDate": "2026-06-15",
  "passengers": 10,
  "cabinClass": "Economy"
}

###

### =====================================================================
###  BOOKINGS — POST /api/bookings
###  Returns 201 Created with BookingResponse (SKY-XXXXXX reference)
### =====================================================================

# Create booking — international, Passport, 2 passengers (GlobalAir)
POST {{api_base}}/bookings
Content-Type: application/json

{
  "flightNumber": "GA-101",
  "provider": "GlobalAir",
  "origin": "JFK",
  "destination": "EZE",
  "departureTime": "2026-06-11T10:30:00",
  "arrivalTime": "2026-06-11T20:45:00",
  "durationMinutes": 615,
  "cabinClass": "Economy",
  "pricePerPerson": 552.00,
  "totalPrice": 1104.00,
  "passengers": 2,
  "passengerDetails": {
    "fullName": "Juan Pérez García",
    "email": "juan.perez@example.com",
    "documentNumber": "A12345678",
    "documentType": "Passport"
  }
}

###

# Create booking — domestic, NationalId, 1 passenger (BudgetWings)
POST {{api_base}}/bookings
Content-Type: application/json

{
  "flightNumber": "BW-520",
  "provider": "BudgetWings",
  "origin": "JFK",
  "destination": "LAX",
  "departureTime": "2026-06-11T06:15:00",
  "arrivalTime": "2026-06-11T11:50:00",
  "durationMinutes": 335,
  "cabinClass": "Economy",
  "pricePerPerson": 162.00,
  "totalPrice": 162.00,
  "passengers": 1,
  "passengerDetails": {
    "fullName": "John Smith",
    "email": "john.smith@example.com",
    "documentNumber": "12345678",
    "documentType": "NationalId"
  }
}

###

# Create booking — international, FirstClass (GlobalAir)
POST {{api_base}}/bookings
Content-Type: application/json

{
  "flightNumber": "GA-103",
  "provider": "GlobalAir",
  "origin": "ATL",
  "destination": "AEP",
  "departureTime": "2026-06-14T08:00:00",
  "arrivalTime": "2026-06-14T18:20:00",
